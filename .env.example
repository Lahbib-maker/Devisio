NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publis_xxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxx

# ── ANTHROPIC IA (optionnel — fallback tarifs fixes) ─────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxx

# ── RESEND EMAILS (optionnel) ─────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# ── STRIPE PAIEMENTS (optionnel) ─────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
